# Linux Fleet Manager - Environment Variables
# Copy this file to variables.env and customize for your environment
# Source this file: source config/variables.env

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================
export LFM_PROJECT_NAME="Linux Fleet Manager"
export LFM_VERSION="1.0.0"
export LFM_AUTHOR="Liquenson Ruben"

# =============================================================================
# PATHS
# =============================================================================
export LFM_ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export LFM_SCRIPTS_DIR="${LFM_ROOT_DIR}/scripts"
export LFM_CONFIG_DIR="${LFM_ROOT_DIR}/config"
export LFM_LOGS_DIR="${LFM_ROOT_DIR}/logs"
export LFM_REPORTS_DIR="${LFM_ROOT_DIR}/reports"
export LFM_TEMP_DIR="${LFM_ROOT_DIR}/tmp"

# =============================================================================
# SERVER INVENTORY
# =============================================================================
export LFM_INVENTORY_FILE="${LFM_CONFIG_DIR}/servers.ini"
export LFM_SSH_USER="admin"
export LFM_SSH_PORT="22"
export LFM_SSH_KEY_PATH="${HOME}/.ssh/id_rsa"

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================
# Number of parallel jobs (adjust based on your system)
export LFM_PARALLEL_JOBS=10

# SSH connection timeout (seconds)
export LFM_SSH_TIMEOUT=10

# Script execution timeout (seconds)
export LFM_EXEC_TIMEOUT=300

# Retry attempts for failed connections
export LFM_RETRY_ATTEMPTS=3

# =============================================================================
# LOGGING
# =============================================================================
export LFM_LOG_LEVEL="INFO"  # DEBUG, INFO, WARN, ERROR
export LFM_LOG_FILE="${LFM_LOGS_DIR}/lfm-$(date +%Y%m%d).log"
export LFM_ENABLE_CONSOLE_LOG=true
export LFM_ENABLE_FILE_LOG=true

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Email notifications (optional)
export LFM_ENABLE_EMAIL_ALERTS=false
export LFM_EMAIL_TO="admin@example.com"
export LFM_EMAIL_FROM="linux-fleet-manager@example.com"
export LFM_SMTP_SERVER="smtp.example.com"

# Slack notifications (optional)
export LFM_ENABLE_SLACK_ALERTS=false
export LFM_SLACK_WEBHOOK_URL=""

# =============================================================================
# BACKUP SETTINGS
# =============================================================================
export LFM_BACKUP_RETENTION_DAYS=30
export LFM_BACKUP_DESTINATION="/backup/servers"
export LFM_BACKUP_COMPRESSION="gzip"  # gzip, bzip2, xz

# =============================================================================
# CLOUD INTEGRATION (Optional)
# =============================================================================
# AWS
export AWS_REGION="eu-west-1"
export AWS_S3_BUCKET=""

# Azure
export AZURE_STORAGE_ACCOUNT=""
export AZURE_STORAGE_CONTAINER=""

# =============================================================================
# MONITORING INTEGRATION
# =============================================================================
# Prometheus Pushgateway
export LFM_PROMETHEUS_PUSHGATEWAY=""

# ELK Stack
export LFM_ELASTICSEARCH_URL=""
export LFM_LOGSTASH_URL=""

# =============================================================================
# COMPLIANCE & SECURITY
# =============================================================================
export LFM_ENABLE_AUDIT_LOG=true
export LFM_AUDIT_LOG_FILE="${LFM_LOGS_DIR}/audit-$(date +%Y%m).log"
export LFM_REQUIRE_SUDO=false
export LFM_VERIFY_SSH_FINGERPRINT=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
export LFM_BATCH_SIZE=50  # Number of servers per batch
export LFM_BATCH_DELAY=5  # Seconds between batches

# =============================================================================
# DEBUG MODE
# =============================================================================
export LFM_DEBUG=false  # Set to true for verbose output
export LFM_DRY_RUN=false  # Set to true to simulate without executing

# =============================================================================
# Create necessary directories
# =============================================================================
mkdir -p "${LFM_LOGS_DIR}"
mkdir -p "${LFM_REPORTS_DIR}"
mkdir -p "${LFM_TEMP_DIR}"

echo "Ō£ģ Linux Fleet Manager environment variables loaded"
echo "Ē│ü Root directory: ${LFM_ROOT_DIR}"
echo "Ē│Ŗ Inventory file: ${LFM_INVENTORY_FILE}"
echo "Ē┤¦ Parallel jobs: ${LFM_PARALLEL_JOBS}"
